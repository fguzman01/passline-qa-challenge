{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",

    "lib": ["ES2020", "DOM"],

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": false,
    "skipLibCheck": true,

    "rootDir": ".",
    "outDir": "dist",

    "types": ["node"]
  },
  "include": [
    "tests",
    "pages",
    "flows",
    "utils",
    "playwright.config.ts"
  ]
}